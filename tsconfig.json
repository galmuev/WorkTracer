{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": false,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "main.js",
    "preload.js",
    "src/main/**/*.js",
    "scripts/check-database.js"
  ],
  "exclude": ["node_modules", "release", "dist"]
}
